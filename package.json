{
  "name": "cpm-agent-app",
  "version": "2.1.0",
  "description": "IBM CPM Program Profile Builder — AI-powered Electron App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "clean": "rm -rf dist",
    "prebuild": "rm -rf dist",
    "build:mac": "electron-builder --mac --x64 --arm64",
    "build:win": "electron-builder --win",
    "test": "jest --testPathPatterns=tests/ --forceExit",
    "test:watch": "jest --testPathPatterns=tests/ --watch",
    "test:coverage": "jest --testPathPatterns=tests/ --coverage --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "coveragePathIgnorePatterns": ["/node_modules/", "/dist/"]
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "docx": "^8.5.0",
    "mammoth": "^1.12.0",
    "node-fetch": "^2.7.0",
    "pdf-parse": "^1.1.4",
    "pptx2json": "^0.0.10",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.0.0",
    "jest": "^30.3.0",
    "rimraf": "^6.1.3"
  },
  "build": {
    "appId": "com.ibm.cpm-assistant",
    "productName": "CPM Assistant",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "services/**",
      "templates/**"
    ],
    "extraResources": [
      {
        "from": "templates",
        "to": "templates"
      }
    ],
    "mac": {
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "keywords": [
    "ibm",
    "cpm",
    "program-manager",
    "electron"
  ],
  "author": "IBM Consulting",
  "license": "ISC"
}
